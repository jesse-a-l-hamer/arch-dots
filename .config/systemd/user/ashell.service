[Unit]
Description=A ready to go Wayland status bar for Hyprland and Niri
Documentation=https://malpenzibo.github.io/ashell/
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target
ConditionEnvironment=WAYLAND_DISPLAY

[Service]
Type=exec
ExecCondition=/lib/systemd/systemd-xdg-autostart-condition "Hyprland" ""
ExecStart=/usr/bin/ashell
Restart=on-failure
Slice=session-graphical.slice

[Install]
WantedBy=graphical-session.target
