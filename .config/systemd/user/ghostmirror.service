[Unit]
Description=Execute ghost mirror
After=network-online.target nss-lookup.target
Wants=network-online.target

[Service]
ExecStartPre=touch %E/ghostmirror/mirrorlist.gm.bak
ExecStart=/usr/bin/ghostmirror -Po -mu %E/ghostmirror/mirrorlist.all -l %E/ghostmirror/mirrorlist -T https -s light -S state,uptodate,morerecent,estimated,speed
Type=oneshot
Restart=on-failure
RestartSec=30m

