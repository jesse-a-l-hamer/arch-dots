[Unit]
Description=Execute ghost mirror
After=network-online.target nss-lookup.target
Wants=network-online.target

[Service]
ExecStart=/usr/bin/ghostmirror -mul %E/ghostmirror/mirrorlist.all %E/ghostmirror/mirrorlist -s light -S state,outofdate,morerecent,estimated,speed
Type=oneshot
Restart=on-failure
RestartSec=30m

